{
  "name": "@sealant/api-contracts",
  "version": "0.4.0",
  "description": "Contract-first HTTP API definitions for Sealant services",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sealant-sh/sealant.git",
    "directory": "packages/api-contracts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "lint": "oxlint .",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@sealant/typescript": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
