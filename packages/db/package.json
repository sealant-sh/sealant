{
  "name": "@sealant/db",
  "version": "0.0.0",
  "private": true,
  "description": "Shared PostgreSQL database package for control-plane state",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./payloads": "./src/payloads.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "drizzle-kit studio",
    "lint": "oxlint .",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/sql": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@sealant/validators": "workspace:*",
    "drizzle-orm": "1.0.0-beta.20",
    "effect": "catalog:",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@sealant/typescript": "workspace:*",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "1.0.0-beta.20"
  }
}
