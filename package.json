{
  "name": "sealant",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:tui": "turbo build --ui=tui",
    "clean": "turbo clean",
    "clean:workspaces": "node tooling/scripts/clean-workspaces.mjs",
    "db:migrate": "pnpm --filter @sealant/db db:migrate",
    "db:studio": "pnpm --filter @sealant/db exec drizzle-kit studio --config drizzle.config.ts",
    "dev": "turbo dev --ui=tui",
    "dev:tui": "turbo dev --ui=tui",
    "format": "oxfmt . --check",
    "format:check": "oxfmt . --check",
    "format:fix": "oxfmt .",
    "lint": "turbo lint --ui=tui",
    "lint:fix": "oxlint . --fix",
    "lint:tui": "turbo lint --ui=tui",
    "lint:types": "oxlint . --type-aware --type-check",
    "playwright:open-google": "node tooling/playwright/open-google.mjs",
    "ssh:setup:dev": "node tooling/scripts/setup-ssh-gateway-dev.mjs",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:tui": "turbo test --ui=tui",
    "test:watch": "vitest",
    "typecheck": "turbo typecheck --ui=tui",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "typecheck:tui": "turbo typecheck --ui=tui"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260315.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
