{
  "name": "sealant",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:tui": "turbo build --ui=tui",
    "clean": "pnpm run clean:workspaces && rm -rf node_modules .turbo",
    "clean:sandboxes": "node tooling/scripts/clean-sandboxes.mjs",
    "clean:turbo": "turbo clean",
    "clean:workspaces": "pnpm -r --parallel exec rm -rf node_modules .turbo",
    "db:migrate": "pnpm --filter @sealant/db db:migrate",
    "db:push": "pnpm --filter @sealant/db db:push",
    "db:studio": "pnpm --filter @sealant/db dev",
    "dev": "turbo dev --ui=tui",
    "dev:tui": "turbo dev --ui=tui",
    "format": "oxfmt . --check",
    "format:check": "oxfmt . --check",
    "format:fix": "oxfmt .",
    "lint": "turbo lint --ui=tui",
    "lint:fix": "oxlint . --fix",
    "lint:tui": "turbo lint --ui=tui",
    "lint:types": "oxlint . --type-aware --type-check",
    "playwright:open-google": "node tooling/playwright/open-google.mjs",
    "prepare": "effect-language-service patch",
    "ssh:setup:dev": "node tooling/scripts/setup-ssh-gateway-dev.mjs",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:tui": "turbo test --ui=tui",
    "test:watch": "vitest",
    "typecheck": "turbo typecheck --ui=tui",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "typecheck:tui": "turbo typecheck --ui=tui"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/platform": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.2",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260315.1",
    "effect-solutions": "^0.5.2",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "@sealant/runtime-protocol": "link:../sealantd/packages/runtime-protocol",
      "@sealant/runtime-client": "link:../sealantd/packages/runtime-client"
    },
    "packageExtensions": {
      "drizzle-orm@1.0.0-beta.20": {
        "dependencies": {
          "effect": "3.21.0"
        }
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
