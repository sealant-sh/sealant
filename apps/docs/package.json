{
  "name": "@sealant/docs",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "deploy": "vite build && wrangler deploy",
    "dev": "vite dev --port 3000",
    "docs:generate": "fumadocs-mdx source.config.ts .source",
    "lint": "oxlint .",
    "prebuild": "pnpm run docs:generate",
    "prelint": "pnpm run docs:generate",
    "pretypecheck": "pnpm run docs:generate",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.2.6",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "fumadocs-core": "^16.7.7",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.7",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@sealant/typescript": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
