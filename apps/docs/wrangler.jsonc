{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sealant-docs",
  "compatibility_date": "2026-03-28",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "routes": [
    {
      "pattern": "docs.sealant.dev",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": true,
  },
}
