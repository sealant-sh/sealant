{
  "name": "@sealant/api",
  "version": "0.0.0",
  "private": true,
  "description": "Control-plane API for validation, orchestration, lifecycle, and state",
  "type": "module",
  "scripts": {
    "build": "BUNDLE_ENTRIES=src/index.ts,src/migrate.ts node ../../tooling/scripts/bundle-app.mjs",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "lint": "oxlint .",
    "test": "vitest run",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@hono/node-server": "^1.18.1",
    "@hono/standard-validator": "^0.2.0",
    "@scalar/hono-api-reference": "^0.9.13",
    "@sealant/api-contracts": "workspace:*",
    "@sealant/db": "workspace:*",
    "@sealant/rabbitmq": "workspace:*",
    "@sealant/sandboxes": "workspace:*",
    "@sealant/source-integrations": "workspace:*",
    "@sealant/telemetry": "workspace:*",
    "@sealant/validators": "workspace:*",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@types/json-schema": "^7.0.15",
    "effect": "catalog:",
    "hono": "^4.8.3",
    "hono-openapi": "^1.3.0",
    "openapi-types": "^12.1.3",
    "zod": "catalog:",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@sealant/typescript": "workspace:*",
    "dotenv-cli": "catalog:"
  }
}
