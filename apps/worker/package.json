{
  "name": "@sealant/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Background worker for sandbox image build jobs",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ./.env.local -e ./.env -e ../../.env.local -e ../../.env -- tsx watch src/index.ts",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sealant/db": "workspace:*",
    "@sealant/rabbitmq": "workspace:*",
    "@sealant/sandboxes": "workspace:*",
    "@sealant/source-integrations": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sealant/typescript": "workspace:*",
    "dotenv-cli": "catalog:"
  }
}
