{
  "name": "@sealant/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Background worker for sandbox image build jobs",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "lint": "oxlint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sealant/db": "workspace:*",
    "@sealant/rabbitmq": "workspace:*",
    "@sealant/sandboxes": "workspace:*",
    "@sealant/source-integrations": "workspace:*",
    "@sealant/validators": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@sealant/typescript": "workspace:*",
    "dotenv-cli": "catalog:"
  }
}
