# URL of the Sealant control-plane API instance
# Used by the web app tRPC server when calling /v1/sandboxes and /v1/registries
VITE_API_URL=http://localhost:4000

# Better Auth configuration for the TanStack Start web app
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
