# URL of the Sealant control-plane API instance
# Used by the web app tRPC server when calling /v1/sandboxes and /v1/registries
VITE_API_URL=http://localhost:4000

# Better Auth configuration for the TanStack Start web app
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Linear OAuth importer
# Create a Linear OAuth2 app with callback http://localhost:3000/api/linear/callback
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_COOKIE_SECRET=replace-with-a-random-32-plus-character-secret
LINEAR_OAUTH_REDIRECT_URI=http://localhost:3000/api/linear/callback
LINEAR_OAUTH_SCOPES=read
LINEAR_IMPORT_PAGE_SIZE=50
LINEAR_IMPORT_MAX_PAGES=2
