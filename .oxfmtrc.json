{
  "arrowParens": "always",
  "printWidth": 100,
  "semi": true,
  "tabWidth": 2,
  "singleQuote": false,
  "trailingComma": "all",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/routeTree.gen.ts",
    ".turbo/**",
    ".direnv/**"
  ],
  "sortImports": {
    "ignoreCase": true,
    "newlinesBetween": true,
    "order": "asc"
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "proseWrap": "always" // printWidth line breaks in MD/MDX
}
