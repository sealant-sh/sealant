GITHUB_API_BASE_URL=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
#---- GH Client Credentials
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# --- Workspace SSH gateway (ssh into a running workspace) ---
# Run `pnpm ssh:setup:dev` — it appends a managed block to THIS .env with the gateway vars
# (TOKEN/HOST/PORT/USERNAME_PREFIX). The API and gateway must agree on the token, so don't set
# these by hand — let the script manage them. The gateway host key autogenerates on first boot
# (gateway-keys volume); your client key is registered through the web app (/setup wizard or
# Settings -> SSH keys).

# --- Local dev infra (optional) ---
# Defaults already match `docker compose up -d` (Postgres :5433, RabbitMQ :5673, zot :5000), so set
# these only to point at non-default infra.
# DATABASE_URL=postgresql://sealant:sealant@127.0.0.1:5433/sealant_control_plane
# RABBITMQ_URL=amqp://sealant:sealant@127.0.0.1:5673
# REGISTRY_BASE_URL=http://127.0.0.1:5000
