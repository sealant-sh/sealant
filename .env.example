GITHUB_API_BASE_URL=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
#---- GH Client Credentials
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Linear OAuth importer for the web app
# Create a Linear OAuth2 app with callback http://localhost:3000/api/linear/callback
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_COOKIE_SECRET=replace-with-a-random-32-plus-character-secret
LINEAR_OAUTH_REDIRECT_URI=http://localhost:3000/api/linear/callback
LINEAR_OAUTH_SCOPES=read
LINEAR_IMPORT_PAGE_SIZE=50
LINEAR_IMPORT_MAX_PAGES=2

# --- Sandbox SSH gateway (ssh into a running sandbox) ---
# Run `pnpm ssh:setup:dev` — it generates the .secrets/* keys + your local SSH config and appends a
# managed block to THIS .env with the gateway vars (TOKEN/HOST/PORT/USERNAME_PREFIX). The API, worker,
# and gateway must all agree on the token, so don't set these by hand — let the script manage them.

# --- Local dev infra (optional) ---
# Defaults already match `docker compose up -d` (Postgres :5433, RabbitMQ :5673, zot :5000), so set
# these only to point at non-default infra.
# DATABASE_URL=postgresql://sealant:sealant@127.0.0.1:5433/sealant_control_plane
# RABBITMQ_URL=amqp://sealant:sealant@127.0.0.1:5673
# REGISTRY_BASE_URL=http://127.0.0.1:5000
